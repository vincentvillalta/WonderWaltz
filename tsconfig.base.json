{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "target":                      "ES2022",
    "module":                      "NodeNext",
    "moduleResolution":            "NodeNext",
    "strict":                      true,
    "exactOptionalPropertyTypes":  true,
    "noUncheckedIndexedAccess":    true,
    "declaration":                 true,
    "declarationMap":              true,
    "sourceMap":                   true,
    "skipLibCheck":                true,
    "resolveJsonModule":           true,
    "esModuleInterop":             true
  }
}
